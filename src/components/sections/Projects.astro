---
import { projects } from "../../data/projects";

interface Props {
  title?: string;
}

const { title } = Astro.props as Props;
---

<section class="w-full py-10 pt-0">
  <div class="mx-auto max-w-6xl px-4">
    {title && (
      <h2 class="text-3xl md:text-4xl font-semibold text-center mb-8 text-foreground">{title}</h2>
    )}

    <div class={`grid gap-6 ${projects.length === 1 ? 'grid-cols-1 max-w-xl mx-auto' : 'grid-cols-1 md:grid-cols-2'}`}>
      {projects.map((p) => (
        <article class="card-surface p-6">
          <div class="flex items-center justify-between">
            <h3 class="text-xl font-semibold text-foreground m-0">{p.title}</h3>
            {p.icons && p.icons.length > 0 && (
              <div class="flex items-center gap-2 [&>span>svg]:w-6 [&>span>svg]:h-6">
                {p.icons.map((icon) => (
                  <span set:html={icon} />
                ))}
              </div>
            )}
          </div>
          <p class="text-sm text-[color:var(--color-text-muted)] m-0">{p.techStack}</p>
          <p class="mt-3 text-[color:var(--color-text-secondary)]">{p.description}</p>
          <div class="mt-6 flex items-center justify-center gap-3">
            <a href={p.ctaLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-1.5 rounded-lg font-semibold px-3 py-2 text-sm no-underline border border-blue-500/80 text-blue-500/80 bg-transparent hover:bg-blue-500/10 starwind-transition-colors">
              <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
              <span class="md:hidden">GitHub</span>
              <span class="hidden md:inline">{p.ctaText}</span>
            </a>
            {p.videoLink && (
              <a href={p.videoLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-1.5 rounded-lg font-semibold px-3 py-2 text-sm no-underline border border-red-500/80 text-red-500/80 bg-transparent hover:bg-red-500/10 starwind-transition-colors">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M18 3a5 5 0 0 1 5 5v8a5 5 0 0 1 -5 5h-12a5 5 0 0 1 -5 -5v-8a5 5 0 0 1 5 -5zm-9 6v6a1 1 0 0 0 1.514 .857l5 -3a1 1 0 0 0 0 -1.714l-5 -3a1 1 0 0 0 -1.514 .857z" /></svg>
                <span class="md:hidden">Video</span>
                <span class="hidden md:inline">Watch Video</span>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>



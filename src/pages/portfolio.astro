---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/sections/Header.astro";
import Footer from "../components/sections/Footer.astro";
import Projects from "../components/sections/Projects.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import GlowLineSeparator from "../components/ui/separator/GlowLineSeparator.astro";
---


<html lang="en" data-theme="dark" class="dark">
  <head>
    <BaseHead title="Portfolio" description="Selected projects and playbooks" />
    <style>main { padding-top: 1.5em; } main section:first-of-type { padding-bottom: 0.5rem; }</style>
  </head>
  <body>
    <Header />
    <main>
      <HeroSection title="Things I've built" subtitle="Open source work and personal projects." />
      <Projects />
      <GlowLineSeparator class="my-8" />
    </main>
    <Footer />
  </body>
</html>



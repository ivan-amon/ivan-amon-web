---
import Layout from '../layouts/BlogPost.astro';
const pageTitle = 'About Me';
const pageDescription = 'Learn more about Iván Amón — Telecom Engineering student at UPM and self-taught software developer.';
---

<Layout title={pageTitle} description={pageDescription} pubDate={new Date()} showHeader={false}>
  <p>
    Hey! I'm Iván Amón, a Network Engineering student at Universidad Politécnica de Madrid (UPM) and a self-taught software developer.
  </p>
  <p>
    University taught me one thing above all: resilience — working through complex architectures, managing frustration, and pushing through until it clicks.
  </p>
  <p>
    Outside of theory, I learn by building. I tinker with Linux systems, develop personal software projects, and deploy containerized architectures with Docker. I also use AI tools like Claude Code to move faster and adopt better practices.
  </p>


</Layout>

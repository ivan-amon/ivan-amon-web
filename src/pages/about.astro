---
import Layout from "../layouts/BlogPost.astro";
import { author } from "../data/author";
const pageTitle = "About — Iván Amón Bystrova";
const pageDescription =
  "About Iván Amón Bystrova (Iván Amón) — Telecom Engineering student at UPM and self-taught software developer focused on backend development and systems programming.";
const avatarUrl = new URL(author.avatar.src, Astro.site).toString();
---

<Layout
  title={pageTitle}
  description={pageDescription}
  pubDate={new Date()}
  showHeader={false}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    mainEntity: {
      '@type': 'Person',
      '@id': new URL('/#person', Astro.site).toString(),
      name: 'Iván Amón Bystrova',
      givenName: 'Iván',
      familyName: 'Amón Bystrova',
      alternateName: ['Iván Amón', 'Ivan Amon Bystrova', 'Ivan Amon'],
      url: new URL('/', Astro.site).toString(),
      image: {
        '@type': 'ImageObject',
        url: avatarUrl,
        caption: 'Iván Amón Bystrova',
      },
      sameAs: [
        'https://www.linkedin.com/in/ivan-amon/',
        'https://github.com/ivan-amon',
      ],
      jobTitle: 'Telecom Engineering Undergraduate | Software Engineer',
      alumniOf: {
        '@type': 'CollegeOrUniversity',
        name: 'Universidad Politécnica de Madrid',
      },
    },
  })} />
  <p>
    Hey! I'm Iván Amón Bystrova, a Software Engineer focused on backend development and
    systems programming.
  </p>
  <p>
    I currently divide my technical focus between constructing
    robust backend architectures (using tools like Laravel and MySQL) and diving
    into low-level systems programming with Rust. I feel at home in Linux
    environments, manage containerized deployments with Docker, and actively
    leverage AI tools like Claude Code to iterate faster and write cleaner code.
  </p>
  <p>
    I balance this hands-on approach with my degree in Telecommunications
    Engineering at UPM. While the university gives me a solid theoretical
    foundation in networking and architectures, its greatest lesson has been
    resilience—the grit to face complex systems, manage frustration when things
    break, and push through until I find the solution.
  </p>
</Layout>
